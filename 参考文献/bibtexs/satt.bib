	month = may,
	year = {2024},
	note = {arXiv:2402.16448 [cs]
TLDR: A large and publicly available trace-based dataset of Starlink measurements, consisting of approximately 140,000 measurements, that comprises all relevant network parameters such as the upload and download throughputs, the RTT, packet loss, and traceroutes is presented.},
	keywords = {Computer Science - Networking and Internet Architecture},
	pages = {1--9},
	file = {Laniewski 等 - 2024 - WetLinks a Large-Scale Longitudinal Starlink Dataset with Contiguous Weather Data.pdf:/Users/kc/Zotero/storage/ADLE5IM8/Laniewski 等 - 2024 - WetLinks a Large-Scale Longitudinal Starlink Dataset with Contiguous Weather Data.pdf:application/pdf;Snapshot:/Users/kc/Zotero/storage/29XLLDNX/2402.html:text/html},
