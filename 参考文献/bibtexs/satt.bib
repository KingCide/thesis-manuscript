	journal = {Sensors},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Kua, Jonathan and Loke, Seng W. and Arora, Chetan and Fernando, Niroshinie and Ranaweera, Chathurika},
	month = jan,
	year = {2021},
	note = {Number: 23
TLDR: A broad overview of the area is presented and a look-ahead of the opportunities made possible by IoT and space-based technologies is provided, to discuss future opportunities for IoT developments, deployment and integration to support future endeavors in space exploration.},
	keywords = {Internet of Things, Machine Learning, Artificial Intelligence, 5G/6G networks, distributed computing, satellite communications, space},
	pages = {8117},
	file = {Kua 等 - 2021 - Internet of Things in Space A Review of Opportunities and Challenges from Satellite-Aided Computing.pdf:/Users/kc/Zotero/storage/APZKKJXF/Kua 等 - 2021 - Internet of Things in Space A Review of Opportunities and Challenges from Satellite-Aided Computing.pdf:application/pdf},
