	journal = {IEEE Network},
	author = {Pan, Huijiang and Yao, Haipeng and Mai, Tianle and Zhang, Ni and Liu, Yunjie},
	month = jul,
	year = {2021},
	note = {TLDR: This article designs an in-network traffic control powered SIN architecture to enhance the network performance and presents two use cases, in- Network load balance and in- network congestion control, to demonstrate the feasibility of the architecture.},
	keywords = {Satellites, Space vehicles, Traffic control, Aerospace electronics, Space communications, Telecommunication traffic},
