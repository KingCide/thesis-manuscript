	author = {Cao, Xuyang and Zhang, Xinyu},
	month = may,
	year = {2023},
	note = {CCF: A
TLDR: SaTCP is presented, a cross-layer solution that enables TCP to avoid overly conservative congestion control and improve its performance under high LEO link dynamics, and increases the goodput by multi-folds compared with state-of-the-art protocols while preserving fairness.
