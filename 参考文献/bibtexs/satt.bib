	keywords = {Data models, Delays, Low earth orbit satellites, Satellites, Computational modeling, Energy consumption, Collaboration, DNN Inference, Dynamic Programming, Heuristic algorithms, Inference algorithms, Kubernetes, LEO Satellites, Remote sensing, Satellite IoT, Simulated Annealing Algorithm},
	pages = {1--1},
	file = {IEEE Xplore Abstract Record:/Users/kc/Zotero/storage/7ZI7UXWK/10738397.html:text/html;Qiao 等 - 2024 - On-orbit DNN distributed inference for remote sensing images in satellite internet of things.pdf:/Users/kc/Zotero/storage/C3EV2F9T/Qiao 等 - 2024 - On-orbit DNN distributed inference for remote sensing images in satellite internet of things.pdf:application/pdf},
