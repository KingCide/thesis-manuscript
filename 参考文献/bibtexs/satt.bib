@misc{shi_satellite_2024,
	title = {Satellite federated edge learning: {Architecture} design and convergence analysis},
	shorttitle = {Satellite {Federated} {Edge} {Learning}},
	url = {http://arxiv.org/abs/2404.01875},
	doi = {10.48550/arXiv.2404.01875},
	abstract = {The proliferation of low-earth-orbit (LEO) satellite networks leads to the generation of vast volumes of remote sensing data which is traditionally transferred to the ground server for centralized processing, raising privacy and bandwidth concerns. Federated edge learning (FEEL), as a distributed machine learning approach, has the potential to address these challenges by sharing only model parameters instead of raw data. Although promising, the dynamics of LEO networks, characterized by the high mobility of satellites and short ground-to-satellite link (GSL) duration, pose unique challenges for FEEL. Notably, frequent model transmission between the satellites and ground incurs prolonged waiting time and large transmission latency. This paper introduces a novel FEEL algorithm, named FEDMEGA, tailored to LEO mega-constellation networks. By integrating inter-satellite links (ISL) for intra-orbit model aggregation, the proposed algorithm significantly reduces the usage of low data rate and intermittent GSL. Our proposed method includes a ring all-reduce based intra-orbit aggregation mechanism, coupled with a network flow-based transmission scheme for global model aggregation, which enhances transmission efficiency. Theoretical convergence analysis is provided to characterize the algorithm performance. Extensive simulations show that our FEDMEGA algorithm outperforms existing satellite FEEL algorithms, exhibiting an approximate 30\% improvement in convergence rate.},
	urldate = {2024-11-13},
	publisher = {arXiv},
	author = {Shi, Yuanming and Zeng, Li and Zhu, Jingyang and Zhou, Yong and Jiang, Chunxiao and Letaief, Khaled B.},
	month = apr,
	year = {2024},
	note = {arXiv:2404.01875},
	keywords = {Computer Science - Machine Learning, Computer Science - Distributed, Parallel, and Cluster Computing, Computer Science - Information Theory, Electrical Engineering and Systems Science - Signal Processing, Mathematics - Information Theory},
	file = {Shi 等 - 2024 - Satellite federated edge learning Architecture design and convergence analysis.pdf:/Users/kc/Zotero/storage/KW7XUN6G/Shi 等 - 2024 - Satellite federated edge learning Architecture design and convergence analysis.pdf:application/pdf;Snapshot:/Users/kc/Zotero/storage/9YR5IE2G/2404.html:text/html},
}

@phdthesis{__2024,
	type = {硕士},
	title = {基于在网计算的分布式机器学习加速技术研究},
	url = {https://kns.cnki.net/kcms2/article/abstract?v=WStw-Pbchox2Y2gkKHi566fO0e0COBhz8A4-Hs373k6HPEAnPSAYsnf-584aDSBUD3MNQhVte7YahAGHy3IVwnN1-RLDxiYaFCvaTkLK2BZD1j7t8w6-3MpjX1WCQew2sHjOvBybxFwcQlRpLhYbfUTYVKJnyKEfQ7yu_IDj9Hija5RFCysN4tAhMT8SldLs&uniplatform=NZKPT&language=CHS},
	doi = {10.27005/d.cnki.gdzku.2024.000531},
	abstract = {作为实现人工智能的重要途径,机器学正在经历前所未有的蓬勃发展。为了获得高质量的机器学模型,业界通常在数据中心内采用分布式机器学来加快训练速度。然而,分布式机器学面临着一些挑战,其中梯度聚合的通信效率是制约整个任务性能的主要瓶颈。在网计算技术为提高分布式机器学的梯度聚合通信效率提供了一个可行的方向,其将梯度聚合任务卸载到可编程交换机中进行,以加速聚合过程,缓解通信瓶颈。然而,该方案面临着可编程交换机处理能力有限以及部署成本高导致的设备数量受限两大挑战,现有工作并未解决这些挑战。为了充分利用有限的在网计算资源,最大化提高任务性能,本文开展基于在网计算的分布式机器学加速技术研究,通过合理规划梯度分配以及梯度聚合功能的放置,有效提高了梯度聚合效率。具体研究内容包括:1)梯度分配和路由的联合优化;2)梯度聚合功能放置和路由的联合优化。(1)针对可编程交换机处理能力有限的挑战,本文提出联合优化梯度分配和路由的方案GAR。其核心思想是允许不同的可编程交换机负责不同梯度块的聚合任务,并为梯度块选择合适的路由,从而实现可编程交换机间的负载均衡。在此基础上,本文以最小化梯度聚合完成时间为目标,对梯度分配与路由联合优化问题进行了形式化建模,并设计了一个基于两阶段随机舍入技术的高效求解算法。为了评估GAR的有效性,本文还实现了一个基于P4可编程交换机的在网聚合系统。实验结果显示,相较于已有方案,GAR能够将聚合完成时间降低约17\%-24\%,极大地提升分布式机器学的梯度数据聚合效率。(2)针对网络中可部署的可编程交换机数量受限这一挑战,本文提出了一种联合优化梯度聚合功能放置和路由的方案SPAR。考虑到聚合吞吐是分布式机器学模型训练中的关键性能指标,本文以最大化聚合吞吐为优化目标,对梯度聚合功能的放置和梯度路由联合优化问题进行形式化建模。为了高效求解该问题,本文采用问题分解的思路,将原问题拆分为放置子问题和路由子问题,针对每个子问题,设计了高效的贪心算法来快速计算解决方案,以期最大限度地提高聚合吞吐。实验结果表明,与现有的工作相比,SPAR通过同时优化放置策略和路由策略,能够有效减少穿越网络的流量,显著提升聚合吞吐。具体而言,SPAR平均可将聚合吞吐提升20\%-64\%,达到了加速分布式机器学模型训练的目的。},
	language = {zh-CN},
	urldate = {2024-11-19},
	school = {电子科技大学},
	author = {杨, 树林},
	year = {2024},
	keywords = {传输加速, 分布式机器学, 梯度聚合, 在网计算},
	file = {PDF:/Users/kc/Zotero/storage/KIUU562F/杨 - 2024 - 基于在网计算的分布式机器学习加速技术研究.pdf:application/pdf},
}

@article{huang_integrated_2024,
	title = {Integrated computing and networking for {LEO} satellite mega-constellations: {Architecture}, challenges and open issues},
	volume = {31},
	issn = {1558-0687},
	shorttitle = {Integrated {Computing} and {Networking} for {LEO} {Satellite} {Mega}-{Constellations}},
	url = {https://ieeexplore.ieee.org/abstract/document/10480332?casa_token=Eic8hXEZ-E8AAAAA:ixFo1NxKQws72k0DopA_EzB3X7eSGne17f6WuptpdEO9UEAIBTMKtZTRT1rifBP9OSRdl5G7Cw},
	doi = {10.1109/MWC.006.2300048},
	abstract = {Low earth orbit (LEO) satellite mega-constellations, with their wide coverage, low delay, and large communication capacity, have become an indis-pensable part of future networks to achieve glob-al coverage. With the remarkable development of edge computing, LEO satellite mega-constellations are starting to have on-orbit computing capabilities to cater to the computing service requirements of the Internet of remote things (loRT). Meanwhile, satellite edge cooperation will most likely be able to overcome single-point satellite resource bottlenecks and improve the utilization of resources. However, most of the existing studies related to satellite edge cooperation have focused on small-scale task scheduling and resource allocation among adjacent nodes. These studies do not fully capture the hetero-geneous and large-scale characteristics of mega-constellations. Furthermore, computing and network resources are optimized separately in these works, which hinders the improvement of service performance. Therefore, this article proposes a new conception called integrated computing and networking for LEO satellite mega-constellations (ICN-LSMC), which breaks the barriers between computing and networking and enables unified management of both. We first analyze the motivation for ICN-LS-MC and present the corresponding design principles. Based on the design principles, we design the system architecture and layered structure of ICN-LSMC. Promising technical challenges are then discussed, including fine-grained resource representation and awareness, ingenious task scheduling, and deterministic routing. To support the feasibility of the proposed architecture, we conduct a performance evaluation. Finally, we highlight some of the potential open issues related to future research.},
	language = {en-US},
	number = {5},
	urldate = {2024-11-21},
	journal = {IEEE Wireless Communications},
	author = {Huang, Tao and Fang, Zeru and Tang, Qinqin and Xie, Renchao and Chen, Tianjiao and Zhang, Ran and Yu, F. Richard},
