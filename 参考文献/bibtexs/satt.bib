@article{huang_integrated_2024-1,
	title = {Integrated computing and networking for {LEO} satellite mega-constellations: {Architecture}, challenges and open issues},
	volume = {31},
	issn = {1558-0687},
	shorttitle = {Integrated {Computing} and {Networking} for {LEO} {Satellite} {Mega}-{Constellations}},
