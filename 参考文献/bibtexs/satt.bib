	keywords = {Delays, distributed multi-agent reinforcement learning, Handover, Low earth orbit satellites, Mega satellite constellations, mobility management strategy, Orbits, Satellite broadcasting, Satellites, space-ground integrated mobility management, streamed low-rank tensor decomposition, Tensors},
