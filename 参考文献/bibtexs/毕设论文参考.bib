@article{kernbach_exploring_nodate,
	title = {Exploring morphing {DDoS} attacks},
	abstract = {In recent years, Distributed Denial of Service (DDoS) attacks have significantly evolved and became increasingly sophisticated. A novel form of these are morphing DDoS attacks, which evade standard defenses by dynamically changing their attack vectors. The next evolution step might be adaptive morphing DDoS attacks, which morph based on real-time data about the state of the target system. These attacks remain underexplored in literature.},
