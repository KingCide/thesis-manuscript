	title = {A distributed collaborative entrance defense framework against {DDoS} attacks on satellite internet},
	volume = {9},
	copyright = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/IEEE.html},
	issn = {2327-4662, 2372-2541},
