    </mxCell>
    <mxCell id="e3" value="Y" style="endArrow=classic;strokeColor=#27AE60;strokeWidth=2;fontSize=10;fontColor=#27AE60;fontStyle=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="check" target="bitmap">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" style="endArrow=classic;strokeColor=#2E86C1;strokeWidth=2;" edge="1" parent="1" source="bitmap" target="qmap">
