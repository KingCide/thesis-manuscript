    <mxCell id="e5" value="N" style="endArrow=classic;strokeColor=#E74C3C;strokeWidth=1.5;dashed=1;fontSize=10;fontColor=#E74C3C;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;curved=1;" edge="1" parent="1" source="check" target="qmap">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="385" y="168"/>
          <mxPoint x="530" y="180"/>
          <mxPoint x="680" y="168"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="bypass_txt" value="跳过位图更新" style="text;fontSize=8;fontColor=#E74C3C;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="480" y="182" width="80" height="12" as="geometry"/>
    </mxCell>

    <!-- ===== 分隔线 ===== -->
    <mxCell id="sep" value="" style="endArrow=none;strokeColor=#BDC3C7;strokeWidth=1;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="20" y="228" as="sourcePoint"/>
        <mxPoint x="780" y="228" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="sep_u" value="↑ 数据平面（每包线速处理）" style="text;fontSize=8;fontColor=#7F8C8D;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="25" y="216" width="180" height="12" as="geometry"/>
    </mxCell>
    <mxCell id="sep_d" value="↓ 星上代理（每 epoch 执行）" style="text;fontSize=8;fontColor=#7F8C8D;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="25" y="230" width="180" height="12" as="geometry"/>
    </mxCell>

    <!-- ========== 星上代理背景 ========== -->
    <mxCell id="ag_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FDEBD0;strokeColor=#E67E22;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="20" y="252" width="760" height="155" as="geometry"/>
    </mxCell>
    <mxCell id="ag_label" value="星上代理（每 Δ = 1.0 s 执行一次）" style="text;fontSize=14;fontStyle=1;fontColor=#784212;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="257" width="320" height="20" as="geometry"/>
    </mxCell>

    <!-- ① 读取 -->
    <mxCell id="a1" value="① 读取&#xa;─────&#xa;Top-K 列表&#xa;bytes 寄存器&#xa;位图缓冲区" style="rounded=1;whiteSpace=wrap;fillColor=#FAE5D3;strokeColor=#E67E22;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="285" width="110" height="75" as="geometry"/>
    </mxCell>

    <!-- ② 特征估计 -->
    <mxCell id="a2" value="② 特征估计&#xa;─────&#xa;R(a) = bytes / Δ&#xa;F̂(a) = −m·ln(Z/m)&#xa;P(a) = Σ𝟙[a∈H]" style="rounded=1;whiteSpace=wrap;fillColor=#FAE5D3;strokeColor=#E67E22;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="190" y="285" width="135" height="75" as="geometry"/>
    </mxCell>

    <!-- ③ 可疑度计算 -->
    <mxCell id="a3" value="③ 可疑度计算&#xa;─────&#xa;归一化: R̃, F̃, P̃&#xa;S = αR̃ + βF̃ + γP̃&#xa;rank = g(S)" style="rounded=1;whiteSpace=wrap;fillColor=#FAE5D3;strokeColor=#E67E22;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="365" y="285" width="140" height="75" as="geometry"/>
    </mxCell>

    <!-- ④ 写回 -->
    <mxCell id="a4" value="④ 写回&#xa;─────&#xa;更新 Ht+1 表项&#xa;更新 rank 表项&#xa;清零位图缓冲" style="rounded=1;whiteSpace=wrap;fillColor=#FAE5D3;strokeColor=#E67E22;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="545" y="285" width="115" height="75" as="geometry"/>
    </mxCell>

    <!-- Agent 内部箭头 -->
