<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ========== 数据平面背景 ========== -->
    <mxCell id="dp_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#EBF5FB;strokeColor=#2E86C1;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="20" y="20" width="760" height="195" as="geometry"/>
    </mxCell>
    <mxCell id="dp_label" value="P4 数据平面（线速流水线）" style="text;fontSize=14;fontStyle=1;fontColor=#1A5276;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="25" width="260" height="20" as="geometry"/>
    </mxCell>

    <!-- Stage labels -->
    <mxCell id="s0" value="Stage 0" style="text;fontSize=8;fontColor=#95A5A6;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="55" y="48" width="70" height="12" as="geometry"/>
    </mxCell>
    <mxCell id="s1" value="Stage 1" style="text;fontSize=8;fontColor=#95A5A6;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="185" y="48" width="90" height="12" as="geometry"/>
    </mxCell>
    <mxCell id="s2" value="Stage 2" style="text;fontSize=8;fontColor=#95A5A6;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="345" y="48" width="70" height="12" as="geometry"/>
    </mxCell>
    <mxCell id="s3" value="Stage 3" style="text;fontSize=8;fontColor=#95A5A6;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="485" y="48" width="90" height="12" as="geometry"/>
    </mxCell>
    <mxCell id="s4" value="Stage 4" style="text;fontSize=8;fontColor=#95A5A6;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="640" y="48" width="80" height="12" as="geometry"/>
    </mxCell>

    <!-- ① Parser -->
    <mxCell id="parser" value="Parser&#xa;───────&#xa;提取 (a, x, len)" style="rounded=1;whiteSpace=wrap;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;fontStyle=0;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="65" width="100" height="55" as="geometry"/>
    </mxCell>

    <!-- ② Top-K 更新 -->
    <mxCell id="topk" value="Top-K 更新&#xa;───────&#xa;bytes(a) += len&#xa;维护候选集 Ht" style="rounded=1;whiteSpace=wrap;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="175" y="63" width="110" height="60" as="geometry"/>
    </mxCell>

    <!-- ③ 候选命中判断 -->
    <mxCell id="check" value="a ∈ Ht ?" style="rhombus;whiteSpace=wrap;fillColor=#FDEBD0;strokeColor=#E67E22;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="340" y="55" width="90" height="80" as="geometry"/>
    </mxCell>

    <!-- ④ FO/FI 位图 -->
    <mxCell id="bitmap" value="FO/FI 位图&#xa;───────&#xa;bitmap[h(x)%m]←1&#xa;双缓冲, K×m bits" style="rounded=1;whiteSpace=wrap;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="475" y="63" width="115" height="60" as="geometry"/>
    </mxCell>

    <!-- ⑤ Queue Map -->
    <mxCell id="qmap" value="Queue Map&#xa;───────&#xa;rank(a) → QID" style="rounded=1;whiteSpace=wrap;fillColor=#D6EAF8;strokeColor=#2E86C1;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="630" y="65" width="100" height="55" as="geometry"/>
    </mxCell>

    <!-- 仅候选 Key 标注 -->
    <mxCell id="cand_note" value="仅候选 Key" style="text;fontSize=8;fontColor=#E67E22;fontStyle=3;" vertex="1" parent="1">
      <mxGeometry x="498" y="126" width="68" height="12" as="geometry"/>
    </mxCell>

    <!-- ===== Packet Path 箭头 ===== -->
    <mxCell id="pkt_label" value="数据包" style="text;fontSize=9;fontColor=#2E86C1;fontStyle=1;align=right;" vertex="1" parent="1">
      <mxGeometry x="-10" y="85" width="42" height="14" as="geometry"/>
    </mxCell>
    <mxCell id="e_in" style="endArrow=classic;strokeColor=#2E86C1;strokeWidth=2;entryX=0;entryY=0.5;" edge="1" parent="1" target="parser">
